# PostgreSQL（5433 = 避让另一项目占用的 5432）
DATABASE_URL=mysql://prdlab:prdlab@localhost:5433/prdlab

# MinIO (S3-compatible)（9100/9101 = 避让另一项目占用的 9000/9001）
MINIO_ENDPOINT=http://localhost:9100
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=prd-lab

# NextAuth v5
# 生成命令：openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# HMAC token for preview cross-domain
# 生成命令：openssl rand -hex 32
HMAC_SECRET=replace-with-openssl-rand-hex-32

# Hosts (matched in /etc/hosts)
MAIN_ORIGIN=http://app.local
PREVIEW_ORIGIN=http://preview.local

# 团队共享登入密码（统一初始密码门禁）。留空 = 关闭密码门禁（dev 行为，仅校验姓名）
# 部署到公网时务必配置，例如：AUTH_SHARED_PASSWORD=changeme-on-deploy
AUTH_SHARED_PASSWORD=
