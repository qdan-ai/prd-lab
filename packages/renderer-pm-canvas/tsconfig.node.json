{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist-node",
    "rootDir": "./node",
    "noEmit": false
  },
  "include": ["node/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-node", "src"]
}
